# WimbledonAce AI — configuration
# Copy to .env and fill in, or export as environment variables.

# DATA SOURCE (default: github = free, no key needed)
# GitHub repo: Tennismylife/TML-Database (ATP matches, rankings, stats)
DATA_SOURCE=github
GITHUB_TENNIS_REPO=Tennismylife/TML-Database
GITHUB_CHARTING_REPO=JeffSackmann/tennis_MatchChartingProject

# RECOMMENDED: upcoming fixtures + bookmaker odds (free tier: 500 req/month)
# Sign up: https://the-odds-api.com/
ODDS_API_KEY=your_odds_api_key

# Kaggle WTA + ATP backup (free, needs ~/.kaggle/kaggle.json)
# bash scripts/download_kaggle.sh
KAGGLE_TENNIS_DATASET=guillemservera/tennis

# Kaggle ATP with historical bookmaker odds — for backtesting
# bash scripts/download_kaggle_odds.sh
KAGGLE_ATP_ODDS_DATASET=dissfya/atp-tennis-2000-2023daily-pull

# OPTIONAL: paid fallback for live fixtures
# Sign up: https://api-tennis.com/
TENNIS_API_KEY=

# OPTIONAL: Telegram alerts
# Create bot via @BotFather, get chat_id via @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Weather: Open-Meteo — no key needed (auto)